# Python
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# 构建产物
build/
dist/*
!dist/审计工具箱.exe
*.spec.bak

# vendor 目录（由 build_suite.py --sync-only 生成，不入库）
vendor/

# 独立模块（各人 git clone，不入库；保留占位与说明）
modules/*
!modules/.gitkeep
!modules/README.md

# IDE 和系统文件
.vscode/
.idea/
.cursor/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# 日志和临时文件
*.log
*.tmp
pack_build.log
