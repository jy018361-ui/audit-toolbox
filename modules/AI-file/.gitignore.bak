.cursor/*
!.cursor/rules/
!.cursor/rules/**
!.cursor/skills/
!.cursor/skills/**
!.cursor/agents/
!.cursor/agents/**
!.cursor/hooks.json

# Excel 临时/锁文件
~$*

# 本地资料库/案例库（体积大，可能包含脱敏但不适合直接入库的底稿）
